# EduSeek — environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in the value.
#
# EMAIL_API_KEY is the bearer token for gmail-smtp-api. It is read
# server-side by the Vite dev plugin (and by the equivalent serverless
# function in production), so it is intentionally NOT prefixed with
# VITE_ — Vite would otherwise bundle it into the client JavaScript.

EMAIL_API_KEY=
